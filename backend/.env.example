# Copy to backend/.env and fill in. Loaded by backend/common/config.py.
#
# Convention: this file holds ONLY secrets (credentials) — it's gitignored, never commit
# real values. Non-secret config (REDIRECT_URI, RECOMMENDER, GEMINI_MODEL, LOG_LEVEL) lives
# in docker-compose*.yml for container runs, and uses sane defaults from config.py for host
# dev. Override a non-secret locally by uncommenting it in the block at the bottom.

# Spotify app credentials — https://developer.spotify.com/dashboard
CLIENT_ID=your_spotify_client_id
CLIENT_SECRET=your_spotify_client_secret

# Signs session cookies. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change_me_to_a_long_random_string

# Free key (no credit card) from https://aistudio.google.com/apikey.
# If unset, the app degrades to the catalog recommender instead of failing.
GEMINI_API_KEY=your_google_ai_studio_key

# --- Non-secret config is set in docker-compose*.yml (with defaults in config.py). ---
# You normally don't set these here; listed for reference:
#   REDIRECT_URI   must exactly match a registered Redirect URI; Spotify forbids
#                  "localhost", so use the loopback IP literal (http://127.0.0.1:PORT/callback)
#   RECOMMENDER    gemini | catalog
#   GEMINI_MODEL   default gemini-2.5-flash
#   LOG_LEVEL      default INFO
